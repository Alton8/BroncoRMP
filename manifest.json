{
  "manifest_version": 3,
  "name": "RMP Extension",
  "version": "1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.ratemyprofessors.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://cmsweb.cms.cpp.edu/*"],
      "js": ["scrapr.js", "storage.js", "content.js"]
    }
  ]
}